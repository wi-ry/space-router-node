# Space Router Home Node — default configuration
# See: https://github.com/gluwa/space-router-node

# Required: Coordination API URL
SR_COORDINATION_API_URL=https://coordination.spacerouter.io

# Optional: override auto-detected public IP
# SR_PUBLIC_IP=

# Optional: node metadata
SR_NODE_LABEL=
SR_NODE_REGION=

# UPnP auto port-forwarding (disable if port is manually forwarded)
SR_UPNP_ENABLED=true

# Listening port
SR_NODE_PORT=9090

# Log level: DEBUG, INFO, WARNING, ERROR
SR_LOG_LEVEL=INFO
